# RecallZero deployment mode
# demo: hackathon-ready mode with sample incident seeding enabled
# production: customer mode with demo seeding hidden and API-guarded
RECALLZERO_MODE=demo
NEXT_PUBLIC_RECALLZERO_MODE=demo

# Optional: disable sample seeding even in demo mode
RECALLZERO_DEMO_SEEDING=true

# Production sign-in readiness
RECALLZERO_SIGNIN_ENABLED=true
RECALLZERO_AUTH_PROVIDER=not-configured
# Comma-separated emails that can access /admin after sign-in
RECALLZERO_ADMIN_EMAILS=owner@example.com
# Optional: require a shared code before creating the judge reviewer session
# RECALLZERO_JUDGE_ACCESS_CODE=judge-review-code

# Stripe billing. Demo mode simulates checkout if these are not set.
RECALLZERO_BILLING_PROVIDER=stripe
NEXT_PUBLIC_APP_URL=https://recallzero-app.vercel.app
RECALLZERO_APP_URL=https://recallzero-app.vercel.app
STRIPE_SECRET_KEY=sk_test_or_live_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_PILOT=price_pilot_monthly
STRIPE_PRICE_PROGRAM=price_program_monthly
# STRIPE_PRICE_ENTERPRISE=price_enterprise_optional

# Optional shared secret for inbound connector webhooks
RECALLZERO_CONNECTOR_WEBHOOK_SECRET=change-me

# Signed app-session cookie secret used by the built-in auth scaffold
RECALLZERO_SESSION_SECRET=change-me-long-random-value

# AWS / DynamoDB production storage
AWS_REGION=us-east-1
DYNAMODB_TABLE_NAME=your-dynamodb-table-name

# Use either Vercel OIDC role credentials:
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/your-vercel-role

# Or static AWS credentials if OIDC is not configured:
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
